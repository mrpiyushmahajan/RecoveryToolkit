# Normalize line endings. PowerShell/CMD are Windows-native: keep CRLF on checkout.
* text=auto

*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

*.md   text eol=lf
*.json text eol=lf

# Binary assets
*.png  binary
*.ico  binary
*.zip  binary
*.exe  binary
