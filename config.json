    },
    {
      "id": "brave",
      "name": "Brave Browser",
      "official": "https://brave.com/download/",
      "download": "https://laptop-updates.brave.com/latest/winx64",
      "silentArgs": "/silent /install"
    },
    {
      "id": "vlc",
      "name": "VLC Media Player",
      "official": "https://www.videolan.org/vlc/",
      "download": "https://get.videolan.org/vlc/last/win64/vlc-latest-win64.exe",
      "silentArgs": "/S"
    },
    {
      "id": "acrobat",
      "name": "Adobe Acrobat Reader",
      "official": "https://get.adobe.com/reader/",
      "download": "https://get.adobe.com/reader/",
      "openPage": true,
      "silentArgs": "/sAll /rs /msi EULA_ACCEPT=YES"
    },
    {
      "id": "malwarebytes",
      "name": "Malwarebytes",
      "official": "https://www.malwarebytes.com/mwb-download",
      "download": "https://downloads.malwarebytes.com/file/mb-windows",
      "silentArgs": "/verysilent"
    },
    {
