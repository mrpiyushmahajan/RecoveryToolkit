{
  "toolkit": {
    "name": "Windows Recovery Toolkit",
    "version": "1.0.3",
    "repository": "https://github.com/mrpiyushmahajan/RecoveryToolkit",
    "updateManifest": "https://api.github.com/repos/mrpiyushmahajan/RecoveryToolkit/releases/latest"
  },
  "settings": {
    "portableMode": true,
    "offlineMode": false,
    "darkMode": true,
    "maxParallelDownloads": 3,
    "downloadRetries": 3,
    "bandwidthLimitKBps": 0,
    "verifyHashes": true,
    "requireHttps": true,
    "logLevel": "Info"
  },
  "paths": {
    "portable": "Portable",
    "installers": "Installers",
    "downloads": "Downloads",
    "drivers": "Drivers",
    "logs": "Logs",
    "reports": "Reports",
    "cache": "Cache"
  },
  "modules": {
    "Download": true,
    "Update": true,
    "Hardware": true,
    "Drivers": true,
    "Repair": true,
    "BootRepair": true,
    "Diagnostics": true,
    "Reports": true,
    "PortableApps": true,
    "UI": true
  },
  "portableApps": [
    {
      "id": "crystaldiskinfo",
