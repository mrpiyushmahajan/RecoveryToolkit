  "installers": [
    {
      "id": "vcredist",
      "name": "Visual C++ Runtime (x64)",
      "official": "https://learn.microsoft.com/cpp/windows/latest-supported-vc-redist",
      "download": "https://aka.ms/vs/17/release/vc_redist.x64.exe",
      "silentArgs": "/install /quiet /norestart"
    },
    {
      "id": "dotnet",
      "name": ".NET Desktop Runtime (x64)",
      "official": "https://dotnet.microsoft.com/download/dotnet",
      "download": "https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x64.exe",
      "silentArgs": "/install /quiet /norestart"
    },
    {
      "id": "directx",
      "name": "DirectX Runtime",
      "official": "https://www.microsoft.com/download/details.aspx?id=35",
      "download": "https://download.microsoft.com/download/1/7/1/1718CCC4-6315-4D8E-9543-8E28A4E18C4C/dxwebsetup.exe",
      "silentArgs": "/Q"
    },
    {
      "id": "chrome",
      "name": "Google Chrome",
      "official": "https://www.google.com/chrome/",
      "download": "https://dl.google.com/tag/s/dl/chrome/install/googlechromestandaloneenterprise64.msi",
      "silentArgs": "/quiet /norestart"
    },
    {
      "id": "firefox",
